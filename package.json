{
  "name": "codemapper",
  "version": "0.1.0",
  "description": "Interactive codebase graph visualizer — infinite canvas for code architecture",
  "type": "module",
  "bin": {
    "codemapper": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/viewer/index.html','dist/viewer/index.html');require('fs').cpSync('node_modules/d3/dist/d3.min.js','dist/viewer/d3.min.js')\"",
    "postinstall": "node -e \"var fs=require('fs');if(fs.existsSync('src/viewer/index.html')){fs.cpSync('src/viewer/index.html','dist/viewer/index.html',{recursive:true,errorOnExist:false});fs.cpSync('node_modules/d3/dist/d3.min.js','dist/viewer/d3.min.js',{errorOnExist:false})}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "d3": "^7.9.0",
    "express": "^4.21.2",
    "open": "^10.0.3",
    "typescript": "^5.9.3",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
