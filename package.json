{
  "name": "codemapper",
  "version": "0.1.0",
  "description": "Interactive codebase graph visualizer — infinite canvas for code architecture",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "codemapper": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node build-viewer.mjs && node -e \"var f=require('fs');f.cpSync('src/viewer/index.html','dist/viewer/index.html');f.cpSync('src/viewer/styles.css','dist/viewer/styles.css');f.cpSync('node_modules/d3/dist/d3.min.js','dist/viewer/d3.min.js');f.cpSync('node_modules/dagre/dist/dagre.min.js','dist/viewer/dagre.min.js');f.cpSync('wasm','dist/wasm',{recursive:true})\"",
    "postinstall": "node -e \"var fs=require('fs');if(fs.existsSync('src/viewer/index.html')){fs.cpSync('src/viewer/index.html','dist/viewer/index.html',{recursive:true,errorOnExist:false});fs.cpSync('src/viewer/styles.css','dist/viewer/styles.css',{errorOnExist:false});fs.cpSync('node_modules/d3/dist/d3.min.js','dist/viewer/d3.min.js',{errorOnExist:false});fs.cpSync('node_modules/dagre/dist/dagre.min.js','dist/viewer/dagre.min.js',{errorOnExist:false});fs.cpSync('wasm','dist/wasm',{recursive:true,errorOnExist:false})}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint --fix src/ && prettier --write 'src/**/*.ts'",
    "format": "prettier --write src/ tests/ *.md *.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "express": "^4.21.2",
    "helmet": "^8.3.0",
    "open": "^10.0.3",
    "web-tree-sitter": "^0.26.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dagre": "^0.7.54",
    "@types/express": "^5.0.1",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
