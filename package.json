{
  "name": "codemapper",
  "version": "0.1.0",
  "description": "Interactive codebase graph visualizer — infinite canvas for code architecture",
  "type": "module",
  "bin": {
    "codemapper": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/viewer/index.html','dist/viewer/index.html')\"",
    "postinstall": "node -e \"require('fs').cpSync('src/viewer/index.html','dist/viewer/index.html',{recursive:true,errorOnExist:false})\"",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "open": "^10.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
